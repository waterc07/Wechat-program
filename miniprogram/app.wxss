page {
  background: #f2f7fb;
  color: #10233a;
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
}

button::after {
  border: none;
}

.card,
.panel-shell {
  background: rgba(255, 255, 255, 0.9);
  border: 1rpx solid rgba(148, 163, 184, 0.18);
  border-radius: 32rpx;
  box-shadow: 0 24rpx 80rpx rgba(15, 23, 42, 0.08);
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #0f172a;
}

.section-kicker {
  font-size: 20rpx;
  letter-spacing: 6rpx;
  text-transform: uppercase;
  color: #0f766e;
}

.muted {
  color: #64748b;
}

.pill-switch {
  display: inline-flex;
  padding: 8rpx;
  border-radius: 999rpx;
  background: rgba(148, 163, 184, 0.14);
  border: 1rpx solid rgba(148, 163, 184, 0.14);
}

.pill-switch-item {
  min-width: 70rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  text-align: center;
  color: #0f766e;
  font-size: 22rpx;
  font-weight: 600;
}

.pill-switch-item-active {
  background: linear-gradient(135deg, #0f766e 0%, #164e63 100%);
  color: #ffffff;
  box-shadow: 0 10rpx 28rpx rgba(15, 118, 110, 0.25);
}

.soft-chip {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(15, 118, 110, 0.08);
  border: 1rpx solid rgba(15, 118, 110, 0.12);
  color: #0f766e;
  font-size: 22rpx;
}

.surface-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #10233a;
}

.surface-subtitle {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.7;
  color: #5b6b80;
}
