.page {
  min-height: 100vh;
  padding: 32rpx 24rpx 40rpx;
  background:
    radial-gradient(circle at top right, rgba(14, 116, 144, 0.18), transparent 32%),
    linear-gradient(180deg, #e6f7fb 0%, #f4f7fb 36%, #f4f7fb 100%);
  box-sizing: border-box;
}

.hero {
  margin-bottom: 24rpx;
}

.hero-topbar {
  display: flex;
  gap: 20rpx;
  justify-content: space-between;
  align-items: flex-start;
}

.hero-copy {
  flex: 1;
}

.hero-title {
  font-size: 46rpx;
  font-weight: 700;
  color: #082f49;
}

.hero-subtitle {
  margin-top: 12rpx;
  line-height: 1.7;
  font-size: 26rpx;
  color: #0f766e;
}

.locale-switch {
  display: inline-flex;
  padding: 8rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.72);
}

.locale-pill {
  min-width: 64rpx;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  text-align: center;
  color: #0f766e;
  font-size: 22rpx;
  font-weight: 600;
}

.locale-pill-active {
  background: #0f766e;
  color: #ffffff;
}

.disclaimer {
  padding: 24rpx;
  margin-bottom: 24rpx;
  border: 2rpx solid rgba(249, 115, 22, 0.16);
  background: #fff7ed;
}

.disclaimer-label {
  margin-bottom: 8rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #c2410c;
}

.disclaimer-text {
  line-height: 1.7;
  font-size: 24rpx;
  color: #7c2d12;
}

.utility-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  align-items: stretch;
  margin-bottom: 24rpx;
}

.endpoint-tip {
  flex: 1 1 100%;
  min-width: 0;
  padding: 16rpx 20rpx;
  border-radius: 18rpx;
  background: rgba(15, 118, 110, 0.08);
}

.endpoint-label {
  margin-bottom: 6rpx;
  color: #0f766e;
  font-size: 20rpx;
}

.endpoint-value {
  color: #155e75;
  font-size: 24rpx;
  line-height: 1.5;
  word-break: break-all;
}

.new-session-button {
  margin: 0;
  padding: 0 28rpx;
  height: 72rpx;
  line-height: 72rpx;
  min-width: 240rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #0f172a;
  font-size: 24rpx;
  box-shadow: 0 10rpx 28rpx rgba(15, 23, 42, 0.08);
}

.messages {
  height: 760rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.empty-state {
  padding: 80rpx 20rpx;
  text-align: center;
}

.message-row {
  display: flex;
  flex-direction: column;
  margin-bottom: 24rpx;
}

.user-row {
  align-items: flex-end;
}

.assistant-row {
  align-items: flex-start;
}

.message-role {
  margin-bottom: 8rpx;
  font-size: 22rpx;
  color: #64748b;
}

.message-bubble {
  max-width: 88%;
  padding: 20rpx 22rpx;
  border-radius: 24rpx;
  line-height: 1.7;
  font-size: 27rpx;
  white-space: pre-wrap;
}

.assistant-bubble {
  background: #ecfeff;
  color: #164e63;
}

.pending-bubble {
  background: #f0fdfa;
  border: 2rpx solid rgba(15, 118, 110, 0.12);
}

.user-bubble {
  background: #0f766e;
  color: #ffffff;
}

.message-meta {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #94a3b8;
}

.user-meta {
  text-align: right;
}

.assistant-meta {
  text-align: left;
}

.thinking-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.thinking-dots {
  display: inline-flex;
  align-items: center;
}

.thinking-dot {
  margin-left: 4rpx;
  font-size: 34rpx;
  line-height: 1;
  color: #0f766e;
  animation: thinkingPulse 1.2s infinite ease-in-out;
}

.dot-2 {
  animation-delay: 0.2s;
}

.dot-3 {
  animation-delay: 0.4s;
}

.composer {
  padding: 24rpx;
}

.composer-input {
  width: 100%;
  min-height: 180rpx;
  padding: 16rpx;
  border-radius: 18rpx;
  background: #f8fafc;
  box-sizing: border-box;
}

.composer-actions {
  display: flex;
  justify-content: space-between;
  margin-top: 20rpx;
}

.primary-button,
.secondary-button {
  flex: 1;
  border-radius: 999rpx;
  font-size: 28rpx;
}

.secondary-button {
  margin-right: 16rpx;
}

.primary-button {
  background: #0f766e;
  color: #ffffff;
}

.primary-button[disabled] {
  background: #5b9b95;
  color: rgba(255, 255, 255, 0.92);
}

.secondary-button {
  background: #e2e8f0;
  color: #0f172a;
}

@keyframes thinkingPulse {
  0%,
  80%,
  100% {
    opacity: 0.25;
    transform: translateY(0);
  }

  40% {
    opacity: 1;
    transform: translateY(-4rpx);
  }
}
