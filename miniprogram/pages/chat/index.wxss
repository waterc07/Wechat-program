.page {
  position: relative;
  min-height: 100vh;
  padding: 28rpx 24rpx 40rpx;
  background:
    linear-gradient(180deg, #edf5fb 0%, #f2f7fb 34%, #f2f7fb 100%);
  box-sizing: border-box;
  overflow: hidden;
}

.page-orbit {
  position: absolute;
  border-radius: 999rpx;
  filter: blur(6rpx);
  pointer-events: none;
}

.orbit-one {
  top: -100rpx;
  right: -60rpx;
  width: 340rpx;
  height: 340rpx;
  background: radial-gradient(circle, rgba(13, 148, 136, 0.2) 0%, rgba(13, 148, 136, 0) 72%);
}

.orbit-two {
  top: 220rpx;
  left: -120rpx;
  width: 280rpx;
  height: 280rpx;
  background: radial-gradient(circle, rgba(14, 116, 144, 0.16) 0%, rgba(14, 116, 144, 0) 72%);
}

.hero-panel,
.notice-panel,
.message-panel,
.composer {
  position: relative;
  z-index: 1;
}

.hero-panel {
  padding: 28rpx;
  margin-bottom: 20rpx;
  background:
    linear-gradient(135deg, rgba(255, 255, 255, 0.96) 0%, rgba(240, 249, 255, 0.92) 100%);
}

.hero-topbar {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  justify-content: space-between;
  align-items: flex-start;
}

.hero-copy {
  flex: 1;
  min-width: 0;
}

.hero-title {
  margin-top: 12rpx;
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1.15;
  color: #0f172a;
}

.hero-subtitle {
  margin-top: 14rpx;
  font-size: 25rpx;
  line-height: 1.8;
  color: #4f647b;
}

.hero-metrics {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 24rpx;
}

.metric-card {
  flex: 1 1 0;
  min-width: 160rpx;
  padding: 20rpx;
  border-radius: 24rpx;
  background: rgba(15, 23, 42, 0.03);
  border: 1rpx solid rgba(148, 163, 184, 0.18);
}

.metric-card-wide {
  flex-basis: 100%;
}

.metric-label {
  font-size: 21rpx;
  color: #64748b;
}

.metric-value {
  margin-top: 10rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #10233a;
}

.metric-endpoint {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #0f766e;
  word-break: break-all;
}

.notice-panel {
  padding: 22rpx 24rpx;
  margin-bottom: 20rpx;
  background: linear-gradient(135deg, #fff9f0 0%, rgba(255, 247, 237, 0.92) 100%);
  border-color: rgba(249, 115, 22, 0.16);
}

.notice-header {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 8rpx;
}

.notice-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #ea580c;
  box-shadow: 0 0 0 10rpx rgba(234, 88, 12, 0.12);
}

.notice-title {
  font-size: 25rpx;
  font-weight: 600;
  color: #c2410c;
}

.notice-text {
  font-size: 23rpx;
  line-height: 1.75;
  color: #7c2d12;
}

.message-panel {
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.panel-toolbar {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.ghost-button {
  margin: 0;
  padding: 0 26rpx;
  min-width: 220rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 999rpx;
  background: rgba(15, 118, 110, 0.08);
  color: #0f766e;
  font-size: 24rpx;
  border: 1rpx solid rgba(15, 118, 110, 0.14);
}

.messages {
  height: 760rpx;
  padding-right: 4rpx;
  box-sizing: border-box;
}

.message-row {
  display: flex;
  flex-direction: column;
  margin-bottom: 24rpx;
}

.assistant-row {
  align-items: flex-start;
}

.user-row {
  align-items: flex-end;
}

.message-meta-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 10rpx;
}

.assistant-meta-row {
  justify-content: flex-start;
}

.user-meta-row {
  justify-content: flex-end;
}

.message-role-chip {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(15, 23, 42, 0.05);
  color: #475569;
  font-size: 20rpx;
}

.message-time {
  font-size: 21rpx;
  color: #94a3b8;
}

.message-bubble {
  max-width: 90%;
  padding: 22rpx 24rpx;
  border-radius: 26rpx;
  font-size: 27rpx;
  line-height: 1.78;
  white-space: pre-wrap;
  border: 1rpx solid transparent;
  box-shadow: 0 16rpx 40rpx rgba(15, 23, 42, 0.06);
}

.assistant-bubble {
  background: linear-gradient(135deg, #ffffff 0%, #ecfeff 100%);
  color: #0f3c4c;
  border-color: rgba(14, 116, 144, 0.1);
}

.user-bubble {
  background: linear-gradient(135deg, #0f766e 0%, #164e63 100%);
  color: #ffffff;
}

.pending-bubble {
  border-color: rgba(15, 118, 110, 0.16);
}

.message-status {
  margin-top: 10rpx;
  font-size: 21rpx;
  color: #94a3b8;
}

.assistant-status {
  text-align: left;
}

.user-status {
  text-align: right;
}

.thinking-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.thinking-dots {
  display: inline-flex;
  gap: 8rpx;
}

.thinking-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #0f766e;
  animation: thinkingPulse 1.2s infinite ease-in-out;
}

.dot-2 {
  animation-delay: 0.2s;
}

.dot-3 {
  animation-delay: 0.4s;
}

.empty-state {
  position: relative;
  padding: 100rpx 24rpx;
  border-radius: 28rpx;
  text-align: center;
  background: linear-gradient(180deg, rgba(248, 250, 252, 0.92) 0%, rgba(255, 255, 255, 0.96) 100%);
  border: 1rpx dashed rgba(148, 163, 184, 0.28);
  overflow: hidden;
}

.empty-grid {
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(148, 163, 184, 0.08) 1rpx, transparent 1rpx),
    linear-gradient(90deg, rgba(148, 163, 184, 0.08) 1rpx, transparent 1rpx);
  background-size: 28rpx 28rpx;
  opacity: 0.4;
}

.empty-state .section-title,
.empty-state .muted {
  position: relative;
}

.empty-hint {
  margin-top: 14rpx;
  line-height: 1.8;
}

.composer {
  padding: 24rpx;
}

.composer-header {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  justify-content: space-between;
  align-items: flex-start;
}

.composer-field {
  margin-top: 20rpx;
  padding: 4rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, rgba(14, 116, 144, 0.14) 0%, rgba(13, 148, 136, 0.06) 100%);
}

.composer-input {
  width: 100%;
  min-height: 180rpx;
  padding: 22rpx 20rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.98);
  box-sizing: border-box;
  font-size: 28rpx;
  line-height: 1.7;
  color: #10233a;
}

.composer-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 20rpx;
}

.outline-button,
.primary-button {
  flex: 1;
  min-width: 240rpx;
  margin: 0;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 600;
}

.outline-button {
  background: rgba(255, 255, 255, 0.88);
  color: #10233a;
  border: 1rpx solid rgba(148, 163, 184, 0.24);
}

.outline-button[disabled] {
  color: #94a3b8;
  background: rgba(248, 250, 252, 0.9);
}

.primary-button {
  background: linear-gradient(135deg, #0f766e 0%, #164e63 100%);
  color: #ffffff;
  box-shadow: 0 16rpx 34rpx rgba(15, 118, 110, 0.24);
}

.primary-button[disabled] {
  background: linear-gradient(135deg, #77aba6 0%, #6b8d9c 100%);
  color: rgba(255, 255, 255, 0.94);
}

@keyframes thinkingPulse {
  0%,
  80%,
  100% {
    opacity: 0.28;
    transform: translateY(0);
  }

  40% {
    opacity: 1;
    transform: translateY(-6rpx);
  }
}
