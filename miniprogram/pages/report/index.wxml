<view class="page">
  <view class="header">
    <view class="header-topbar">
      <view>
        <view class="header-title">{{t.reportHeaderTitle}}</view>
        <view class="header-subtitle">{{t.reportHeaderSubtitle}}</view>
      </view>
      <view class="locale-switch">
        <block wx:for="{{localeOptions}}" wx:key="code">
          <view
            class="locale-pill {{locale === item.code ? 'locale-pill-active' : ''}}"
            data-locale="{{item.code}}"
            bindtap="switchLocale"
          >
            {{item.shortLabel}}
          </view>
        </block>
      </view>
    </view>
    <view class="action-row">
      <button class="action-button" bindtap="backToChat">{{t.continueConsultation}}</button>
      <button class="action-button" bindtap="startNewConsultation">{{t.startNewConsultation}}</button>
      <button class="action-button action-primary" bindtap="regenerateReport" disabled="{{loading || regenerating}}">
        {{regenerating ? t.regeneratingReport : t.regenerateReport}}
      </button>
    </view>
  </view>

  <view wx:if="{{loading}}" class="loading card">
    <view class="muted">{{t.reportLoading}}</view>
  </view>

  <view wx:elif="{{report}}" class="content">
    <view class="report-card card">
      <view class="field-label">{{t.fieldSymptoms}}</view>
      <view class="field-value">{{report.symptoms_summary}}</view>
    </view>

    <view class="report-card card">
      <view class="field-label">{{t.fieldConditions}}</view>
      <block wx:for="{{report.possible_conditions}}" wx:key="*this">
        <view class="tag">{{item}}</view>
      </block>
    </view>

    <view class="report-card card">
      <view class="field-label">{{t.fieldDepartment}}</view>
      <view class="field-value">{{report.recommended_department}}</view>
    </view>

    <view class="report-card card">
      <view class="field-label">{{t.fieldUrgency}}</view>
      <view class="field-value urgency">{{report.urgency_level}}</view>
    </view>

    <view class="report-card card">
      <view class="field-label">{{t.fieldAdvice}}</view>
      <view class="field-value">{{report.next_step_advice}}</view>
    </view>

    <view class="report-card card warning">
      <view class="field-label">{{t.fieldDisclaimer}}</view>
      <view class="field-value">{{locale === 'en-US' ? disclaimer : (report.disclaimer || disclaimer)}}</view>
    </view>
  </view>
</view>
