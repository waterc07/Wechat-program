.page {
  min-height: 100vh;
  padding: 32rpx 24rpx 40rpx;
  background:
    linear-gradient(180deg, rgba(14, 116, 144, 0.12) 0%, rgba(244, 247, 251, 1) 28%),
    #f4f7fb;
  box-sizing: border-box;
}

.header {
  margin-bottom: 24rpx;
}

.header-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #082f49;
}

.header-subtitle {
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #155e75;
}

.loading,
.report-card {
  padding: 26rpx;
  margin-bottom: 20rpx;
}

.field-label {
  margin-bottom: 14rpx;
  font-size: 25rpx;
  font-weight: 600;
  color: #475569;
}

.field-value {
  font-size: 28rpx;
  line-height: 1.8;
  color: #0f172a;
  white-space: pre-wrap;
}

.tag {
  display: inline-block;
  margin: 0 12rpx 12rpx 0;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #ecfeff;
  color: #155e75;
  font-size: 24rpx;
}

.urgency {
  color: #c2410c;
  font-weight: 600;
}

.warning {
  background: #fff7ed;
}

